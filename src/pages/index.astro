---
import VideoPlaylist from '../components/VideoPlaylist.svelte';
import { videos, categories } from '../data/videos.js';
import '../styles/global.css';
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Soccer Recruiting video portfolio for Audrey Derifaj, Class of 2026." />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Audrey Derifaj | Soccer Recruiting</title>
		<!-- Google Fonts for modern typography -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
	</head>
	<body class="bg-slate-950 text-slate-200 font-sans antialiased selection:bg-blue-500/30 selection:text-white min-h-screen flex flex-col">
		
		<!-- Header / Hero Section -->
		<header class="relative overflow-hidden border-b border-white/5 py-16 md:py-24">
			<!-- Background effects -->
			<div class="absolute inset-0 z-0">
				<div class="absolute top-[-20%] left-[-10%] w-[50%] h-[50%] rounded-full bg-courage-navy/40 blur-[120px]"></div>
				<div class="absolute bottom-[-20%] right-[-10%] w-[50%] h-[50%] rounded-full bg-courage-red/20 blur-[120px]"></div>
				<div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1579952363873-27f3bade9f55?q=80&w=2000&auto=format&fit=crop')] bg-cover bg-center opacity-[0.03]"></div>
			</div>
			
			<div class="container mx-auto px-6 relative z-10 text-center max-w-4xl">
				<div class="flex flex-wrap gap-4 justify-center mb-6">
					<span class="inline-block py-1 px-3 rounded-full bg-courage-navy/50 text-courage-blue text-xs font-semibold tracking-wider uppercase border border-courage-blue/30 shadow-sm shadow-courage-blue/10">
						Class of 2026
					</span>
					<span class="inline-block py-1 px-3 rounded-full bg-courage-red/20 text-red-300 text-xs font-semibold tracking-wider uppercase border border-courage-red/40 shadow-sm shadow-courage-red/10">
						Elite Engine (8th in NC XC)
					</span>
				</div>
				<h1 class="text-5xl md:text-7xl font-bold text-white mb-6 tracking-tight flex flex-col md:flex-row items-center justify-center gap-4">
					<img src="/images/North_Carolina_Courage_logo.svg" alt="NC Courage Logo" class="h-16 md:h-20 w-auto drop-shadow-[0_0_15px_rgba(227,24,55,0.3)]" />
					<span>Audrey <span class="text-transparent bg-clip-text bg-gradient-to-r from-courage-blue to-white">Derifaj</span></span>
				</h1>
				<p class="text-lg md:text-xl text-slate-400 max-w-2xl mx-auto leading-relaxed">
					U16 NC Courage Academy • Coached by Kendell Fletcher White<br/>
					Holder of all-time HS 3KM and 5KM records with exceptional stamina.
				</p>
			</div>
		</header>

		<!-- Main Content Area -->
		<main class="flex-grow py-12 md:py-16 px-4 sm:px-6">
			<!-- Note: 'client:load' tells Astro to hydrate the Svelte component immediately -->
			<VideoPlaylist videos={videos} categories={categories} client:load />
		</main>

		<!-- Footer -->
		<footer class="border-t border-white/5 py-8 mt-auto text-center text-slate-500 text-sm">
			<div class="container mx-auto">
				<p>Audrey Derifaj Recruiting &copy; {new Date().getFullYear()}</p>
				<p class="mt-2 text-slate-600">Contact: audrey.soccer@example.com</p>
			</div>
		</footer>

	</body>
</html>

<style is:global>
	/* Using Inter font from Google Fonts globally */
	body {
		font-family: 'Inter', sans-serif;
	}
</style>
